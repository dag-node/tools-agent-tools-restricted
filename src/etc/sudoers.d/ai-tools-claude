# /etc/sudoers.d/ai-tools-claude
# Allow the normal user to:
#   1. execute claude-run as @SANDBOX_USER@ (wrapper resolves the versioned claude path,
#      exports it as CLAUDE_EXEC, then calls claude-run which wraps the session in a systemd
#      transient service (--user --pty) with RestrictNamespaces=yes + UMask=0007;
#      NoNewPrivileges is intentionally ABSENT -- the session itself runs under NNP because
#      RestrictNamespaces forces PR_SET_NO_NEW_PRIVS, but claude-run must not set NNP at the
#      scope it occupies before exec, or sudo's own PAM authentication breaks)
#   2. run nvm-update.sh as @SANDBOX_USER@ (called from nvm-update.sh running as @PROJECTS_USER@)
#   3. run ai-tools-relabel-entrypoint as ROOT (called from nvm-update.sh after the sandbox
#      update, to restore ai_tools_exec_t on the new claude.exe; see the security note below)
#
# NOTE: @SANDBOX_USER@ has NO sudo rights in this file.  Ownership handback
# (ai-tools-chown, ai-tools-setgid, ai-tools-claude-symlink) is now handled by the
# ai-tools-handback socket daemon (a root-owned service started at boot) via the
# /usr/local/bin/ai-tools-handback-client.  This replaces the former three
# @SANDBOX_USER@ NOPASSWD rules, which were broken under NNP anyway (PR_SET_NO_NEW_PRIVS
# is forced by RestrictNamespaces=yes, dropping sudo's SUID bit silently).
#
# The umask, env_keep, and umask_override Defaults are scoped per-command
# (Defaults!<command>), not to all of @PROJECTS_USER@'s sudo, so they apply
# ONLY to these commands and never alter the user's other sudo invocations:
#   - umask=0007 + umask_override (claude-run): sets claude-run's own process umask.
#     A service unit does NOT inherit the caller's umask (a scope did), so the agent's
#     umask is set authoritatively by the UMask=0007 property claude-run puts on the
#     unit -- giving files 660/770 rather than 600/700. Both @PROJECTS_USER@ and
#     @SANDBOX_USER@ are co-writers on project files across sessions; world bits are
#     still stripped (o=0). A stricter umask (e.g. 0027) would give group read-only
#     after handback, blocking Claude's Edit tool (in-place patch) on handed-back files.
#   - env_keep CLAUDE_EXEC CLAUDE_PROJECT_DIR (claude-run): the versioned claude path
#     resolved and validated by the wrapper is passed through sudo so claude-run can
#     re-validate and exec it directly; CLAUDE_PROJECT_DIR carries the validated project
#     dir and becomes the transient unit's WorkingDirectory (units default to /).
#   - env_keep AI_TOOLS_GLOBAL_TOOLS/NVM_NODE_MAJOR/NVM_NODE_ALIAS (nvm-update.sh):
#     passes service-configured package/version variables through sudo so the
#     @SANDBOX_USER@ invocation sees the same values @PROJECTS_USER@ resolved.
#
# SECURITY NOTES:
#   - NOPASSWD is intentional: all three commands are called non-interactively (the
#     daily nvm-update timer has no tty to prompt at).
#   - claude-run is at a fixed, non-glob path (550 @PROJECTS_USER@:@SANDBOX_GROUP@,
#     not writable by @SANDBOX_USER@). The versioned claude binary is no longer a
#     direct sudo target; it is exec'd by claude-run after re-validation of CLAUDE_EXEC.
#   - The nvm-update.sh argument must match a vMAJOR.MINOR.PATCH version; a single
#     glob arg cannot span into extra arguments (sudo matches argv count), so no
#     trailing flags can be injected.
#   - ai-tools-relabel-entrypoint runs AS ROOT (the other two drop to @SANDBOX_USER@):
#     restoring the ai_tools_exec_t label on the new claude entrypoint needs unconfined_t,
#     which root holds. The grant is scoped to that one action -- a FIXED, non-glob path
#     with NO arguments resolves to one program doing one thing (restorecon the nvm-tree
#     claude.exe), and the helper is 750 root:root, owned and writable by root alone. It is
#     an operator (@PROJECTS_USER@) grant, keeping the root privilege on the operator side
#     alongside the other two rather than in the agent-reachable handback domain.
#   - The two @SANDBOX_USER@-target rules DROP privilege (run as the lower-privileged
#     @SANDBOX_USER@); the agent runs AS @SANDBOX_USER@ and cannot invoke a
#     @PROJECTS_USER@ rule, so NONE of the three grants the agent anything -- including
#     the root relabel rule, which @SANDBOX_USER@ cannot reach.
#   - @SANDBOX_USER@ has no login shell and no other sudo rights.
#   - @PROJECTS_USER@ is substituted with the real username by install.sh.
#
# Syntax check before deploy:  visudo -c -f /etc/sudoers.d/ai-tools-claude

Defaults!/opt/ai-tools/bin/claude-run umask=0007,umask_override
Defaults!/opt/ai-tools/bin/claude-run env_keep += "CLAUDE_EXEC CLAUDE_PROJECT_DIR"
Defaults!/opt/ai-tools/bin/nvm-update.sh env_keep += "AI_TOOLS_GLOBAL_TOOLS NVM_NODE_MAJOR NVM_NODE_ALIAS"

@PROJECTS_USER@ ALL=(@SANDBOX_USER@:@SANDBOX_GROUP@) NOPASSWD: /opt/ai-tools/bin/claude-run
@PROJECTS_USER@ ALL=(@SANDBOX_USER@:@SANDBOX_GROUP@) NOPASSWD: /opt/ai-tools/bin/nvm-update.sh v[0-9]*.[0-9]*.[0-9]*
@PROJECTS_USER@ ALL=(root) NOPASSWD: /usr/local/sbin/ai-tools/ai-tools-relabel-entrypoint
