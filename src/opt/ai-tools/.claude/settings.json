{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "disableAutoMode": "disable",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff --staged*)",
      "Bash(git diff --cached*)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(shellcheck *)",
      "Bash(rpmlint *)",
      "Bash(yamllint *)",
      "Bash(jq *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(stat *)",
      "Bash(getfacl *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort)",
      "Bash(sort *)",
      "Bash(uniq)",
      "Bash(uniq *)",
      "Bash(grep *)",
      "Bash(file *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(sudo)",
      "Bash(sudo *)",
      "Bash(su)",
      "Bash(su *)",
      "Bash(dnf)",
      "Bash(dnf *)",
      "Bash(yum)",
      "Bash(yum *)",
      "Bash(mount)",
      "Bash(mount *)",
      "Bash(umount)",
      "Bash(umount *)",
      "Bash(setenforce *)",
      "Bash(semodule)",
      "Bash(semodule *)",
      "Bash(semanage)",
      "Bash(semanage *)",
      "Bash(df)",
      "Bash(df *)",
      "Bash(du)",
      "Bash(du *)",
      "Bash(ps)",
      "Bash(ps *)",
      "Bash(id)",
      "Bash(id *)",
      "Bash(getent *)",
      "Bash(rpm)",
      "Bash(rpm *)",
      "Bash(getenforce)",
      "Bash(matchpathcon *)",
      "Bash(readlink *)",
      "Bash(journalctl)",
      "Bash(journalctl *)",
      "Bash(systemctl)",
      "Bash(systemctl *)",
      "Bash(ausearch)",
      "Bash(ausearch *)",
      "Bash(auditctl)",
      "Bash(auditctl *)",
      "Bash(aureport)",
      "Bash(aureport *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/ai-tools/.claude/post-tool-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/ai-tools/.claude/session-hook.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/ai-tools/.claude/session-hook.sh session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/ai-tools/.claude/session-hook.sh session-end"
          }
        ]
      }
    ]
  }
}
