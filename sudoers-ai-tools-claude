# /etc/sudoers.d/ai-tools-claude
# Allow the normal user to execute claude as ai-tools without a password.
# The wrapper resolves the real versioned path via realpath before calling
# sudo, so the glob below will match exactly one binary at runtime.
#
# SECURITY NOTES:
#   - NOPASSWD is intentional: the wrapper is called from an IDE terminal
#     where interactive password prompts are not viable.
#   - The allowed command is scoped to a single binary under a known path.
#   - The ai-tools user has no login shell and no sudo rights of its own.
#   - Replace 'dag' with the actual normal username.
#
# Syntax check before deploy:  visudo -c -f /etc/sudoers.d/ai-tools-claude

Defaults:xd !lecture, !authenticate
dag ALL=(ai-tools:ai-tools) NOPASSWD: /home/dag/.nvm/versions/node/*/bin/claude
