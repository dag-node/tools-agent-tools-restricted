# /etc/sudoers.d/ai-tools-claude
# Allow the normal user to:
#   1. execute claude as ai-tools (wrapper resolves the versioned path with a single readlink hop)
#   2. run nvm-update.sh as ai-tools (called from nvm-update.sh running as @PROJECTS_USER@)
#
# Allow ai-tools to:
#   3. restore @PROJECTS_USER@:ai-tools ownership on files it writes within approved
#      project directories (see /usr/local/sbin/ai-tools/chown and the allowlist at
#      ~/.config/ai-tools/allowed-projects)
#   4. normalize group + setgid on approved project directories at session start, so
#      files @PROJECTS_USER@ creates there inherit the @SANDBOX_GROUP@ group (see
#      /usr/local/sbin/ai-tools/setgid; re-validates the path against the allowlist).
#   5. repoint the stable /opt/ai-tools/bin/claude symlink at a validated versioned
#      binary after a Node upgrade (see /usr/local/sbin/ai-tools/claude-symlink).
#      bin is locked 550 @PROJECTS_USER@:ai-tools, so this root helper is the only
#      path by which the sandbox updater can move the symlink.
#
# The umask and env_keep Defaults are scoped per-command (Defaults!<command>),
# not to all of @PROJECTS_USER@'s sudo, so they apply ONLY to these two commands
# and never alter the user's other sudo invocations:
#   - umask=0007 (claude) ensures Claude Code creates files 660/770 rather than
#     600/700, making both @PROJECTS_USER@ and ai-tools natural co-writers on
#     project files across sessions. World bits are still stripped (o=0). A
#     stricter umask (e.g. 0027) would give group read-only after handback,
#     blocking Claude's Edit tool (in-place patch) on previously handed-back files
#     and forcing unnecessary full-file rewrites.
#   - env_keep (nvm-update.sh) passes the service-configured package/version
#     variables through sudo so the ai-tools invocation sees the same values the
#     @PROJECTS_USER@ invocation resolved from the systemd environment.
#
# SECURITY NOTES:
#   - NOPASSWD is intentional: both commands are called non-interactively.
#   - Allowed targets are scoped to specific paths under /opt/ai-tools.
#   - The nvm-update.sh argument must match a vMAJOR.MINOR.PATCH version; a single
#     glob arg cannot span into extra arguments (sudo matches argv count), so no
#     trailing flags can be injected.
#   - Both @PROJECTS_USER@ rules DROP privilege (run as the lower-privileged
#     ai-tools); the agent runs AS ai-tools and cannot invoke an @PROJECTS_USER@
#     rule, so neither grants the agent anything it does not already have.
#   - ai-tools-chown validates against a user-owned allowlist before acting.
#   - The ai-tools user has no login shell and no other sudo rights.
#   - @PROJECTS_USER@ is substituted with the real username by install.sh.
#
# Syntax check before deploy:  visudo -c -f /etc/sudoers.d/ai-tools-claude

Defaults!/opt/ai-tools/.nvm/versions/node/*/bin/claude umask=0007,umask_override
Defaults!/opt/ai-tools/bin/nvm-update.sh env_keep += "AI_TOOLS_GLOBAL_TOOLS NVM_NODE_MAJOR NVM_NODE_ALIAS"

@PROJECTS_USER@ ALL=(@SANDBOX_USER@:@SANDBOX_GROUP@) NOPASSWD: /opt/ai-tools/.nvm/versions/node/*/bin/claude
@PROJECTS_USER@ ALL=(@SANDBOX_USER@:@SANDBOX_GROUP@) NOPASSWD: /opt/ai-tools/bin/nvm-update.sh v[0-9]*.[0-9]*.[0-9]*

@SANDBOX_USER@ ALL=(root) NOPASSWD: /usr/local/sbin/ai-tools/chown
@SANDBOX_USER@ ALL=(root) NOPASSWD: /usr/local/sbin/ai-tools/setgid
@SANDBOX_USER@ ALL=(root) NOPASSWD: /usr/local/sbin/ai-tools/claude-symlink /opt/ai-tools/.nvm/versions/node/v[0-9]*
