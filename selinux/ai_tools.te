policy_module(ai_tools, 0.5.0)

## ============================================================
## POLICY GROUP DEFAULTS -- this core module covers repo-only work.
## All optional groups are DISABLED by default. Enable them only when
## tasks require reaching into system context beyond project files.
##
## Group     Default    Surface added
## --------  ---------  ----------------------------------------------------
## systemd   disabled   systemctl, journalctl, systemd unit file reads
## pkgmgmt   disabled   rpm (rpm_exec_t), dnf RPM database (rpm_var_lib_t)
## netadmin  disabled   firewall-cmd D-Bus (firewalld_t), nmcli D-Bus (NM_t)
## podman    disabled   podman/buildah exec (container_runtime_exec_t),
##                      container image/layer storage (container_file_t)
##
## Manage groups via install-selinux.sh:
##   sudo selinux/install-selinux.sh list-groups
##   sudo selinux/install-selinux.sh enable-group  <name>
##   sudo selinux/install-selinux.sh disable-group <name>
##
## When a task fails because a group is not loaded the agent will surface:
##   "Enable the '<name>' policy group (why: <reason>):
##    ! sudo selinux/install-selinux.sh enable-group <name>"
## ============================================================

########################################
#
# ai_tools -- confine the Claude Code sandbox agent (the ai-tools UID) to its own
# domain (ai_tools_t) with a path boundary: it may modify approved project dirs
# (ai_tools_project_t), its own config/state (ai_tools_home_t), and private temp
# (ai_tools_tmp_t), but NOT other user files (e.g. other projects under /home,
# still user_home_t), and it may NOT read other domains' process state or the
# invoking user's home/config.
#
# SHIPS PERMISSIVE. Loading this module changes NOTHING about what is allowed --
# it only LOGS what ai_tools_t does. The single `permissive ai_tools_t;` line at
# the bottom is the on/off switch; remove it (and reload) to enforce. See
# selinux/README.md.
#
# v0.2.0 folds in the first audit2allow bring-up pass. The guiding rule was the
# opposite of `audit2allow | tee policy`: a raw audit2allow dump asks to allow
# everything observed, including ~45 daemon /proc reads, listing the user's home,
# and writing usr_t. Those are NOT granted here -- they are the boundary. Each is
# dontaudit'd (with the reason) so it stays silently denied under enforcing. Only
# the accesses the agent genuinely needs to function are allowed, via refpolicy
# interfaces wherever one exists.
#
########################################

require {
    type unconfined_t;
    role unconfined_r;

    # read-only kernel tunables Node/V8 probes at startup
    type sysctl_vm_t;

    # types we deliberately REFUSE (dontaudit below -- logged-then-silenced, never
    # allowed). Declared here so the explicit dontaudit rules compile.
    type config_home_t;
    type container_file_t;
    type sendmail_exec_t;
    type home_root_t;
    type user_home_dir_t;
    type user_home_t;
    type cgroup_t;
    type fs_t;
    type tmpfs_t;
    type tty_device_t;
    type usb_device_t;
    type kernel_t;
    type init_t;

    # process2 carries the NNP bounded-transition permission (RHEL/Rocky 9+).
    # Required because the session always runs under NO_NEW_PRIVS (forced by the
    # RestrictNamespaces seccomp filter claude-run sets); see the domain-entry block.
    class process2 nnp_transition;
}

########################################
# Types
########################################

# The confined agent (claude.exe running as the ai-tools UID).
# application_domain() declares the domain, marks ai_tools_exec_t its entrypoint,
# and grants the baseline every userspace app needs (ld.so, shared libraries).
type ai_tools_t;
type ai_tools_exec_t;
application_domain(ai_tools_t, ai_tools_exec_t)

# Approved project directories the agent may read/write. Applied per-project with
# `semanage fcontext` (see the ai-tools CLI / selinux/install-selinux.sh),
# not in ai_tools.fc, because project paths are dynamic.
type ai_tools_project_t;
files_type(ai_tools_project_t)

# The agent's own config/state -- /opt/ai-tools/.claude plus its HOME state files
# (.claude.json, .npm, .cache, .local, .config; see ai_tools.fc). A private
# writable area distinct from the read-only nvm/program tree (usr_t), so the
# policy need not grant write to usr_t. The <you>-owned control files inside
# (settings.json, post-tool-hook.sh) stay protected by DAC regardless of label.
type ai_tools_home_t;
files_type(ai_tools_home_t)

# The agent's private temp files. A type_transition (below) relabels everything
# the agent creates under /tmp to this type, so it gets its own scratch space and
# cannot read or clobber other domains' tmp_t/user_tmp_t files once enforcing.
type ai_tools_tmp_t;
files_tmp_file(ai_tools_tmp_t)

# The user-owned ai-tools config the ROOT helpers must read on the agent's behalf:
# ~/.config/ai-tools/{allowed-projects,secret-patterns}. Those paths are normally
# config_home_t, which the dontaudit block below REFUSES to ai_tools_t. But
# ai-tools-chown runs IN ai_tools_t (sudo, no transition) and its first real step
# is reading allowed-projects (ai-tools-chown.sh line 59); with no read grant the
# getattr is denied and the helper fail-closes to a silent exit 0 -- so NO file is
# ever handed back. A dedicated type labels just this subtree so the helper can
# read it WITHOUT opening all of ~/.config to the agent. The DAC 700 on the dir
# still blocks the non-root agent; only the root helper (DAC-exempt, SELinux-gated)
# benefits. <you> (unconfined) reads it regardless of label. Mirrors the
# libs_read_lib_files grant for the secret-pattern library -- same "the root helper
# in ai_tools_t must read a user/lib file or handback breaks" reasoning.
type ai_tools_conf_t;
files_type(ai_tools_conf_t)

# The root-helper operation logs under /var/log/ai-tools (labelled by ai_tools.fc).
# The root helpers (chown, setgid, claude-symlink) run IN ai_tools_handback_t and
# append their privileged-operation records here. logging_log_file marks the type a
# system log file so it lands under the right relabel/restorecon rules. The DAC mode
# (dir root:root 700, files 600) keeps the agent out -- this only lets the root-uid
# helper write under enforcing. (ai-tools-lockdown and the CLI run unconfined; the hooks
# log to journald via the already-granted /dev/log path, not to these files.)
type ai_tools_log_t;
logging_log_file(ai_tools_log_t)

# The AF_UNIX socket and /run/ai-tools runtime directory.  ai_tools_t connects here;
# the socket file is created by systemd when ai-tools-handback.socket activates.
type ai_tools_run_t;
files_type(ai_tools_run_t)

# The handback privilege bridge daemon.  Runs as root (system manager service),
# accepts one connection per instance, authenticates via SO_PEERCRED, then
# calls the existing root helpers.  Starts permissive until the AVC log is clean
# on the live box; see the bring-up loop in selinux/README.md.
type ai_tools_handback_t;
type ai_tools_handback_exec_t;
init_daemon_domain(ai_tools_handback_t, ai_tools_handback_exec_t)

########################################
# Domain entry
########################################

# claude is launched as a transient systemd --user *service* (claude-run uses
# `systemd-run --user --pty`), so the final exec of the labelled claude.exe is done
# by @SANDBOX_USER@'s user-manager, NOT by the sudo/systemd-run caller. Two domtrans
# sources are authorised:
#   - init_t        the user-manager domain on RHEL/Rocky 9 targeted policy; the live
#                   path for a service-unit launch. The service directive
#                   RestrictNamespaces=yes (set in claude-run) requires service mode --
#                   systemd 252 rejects it on a scope unit -- which is why the exec
#                   moved off the unconfined_t caller and onto the manager.
#   - unconfined_t  retained for a direct exec (claude run outside the service wrapper,
#                   or a --scope fallback) so confinement still applies there.
#
# VERIFY ON THE LIVE BOX before enforcing -- two points this module cannot check
# from inside the sandbox:
#   (1) domain: confirm the user-manager is init_t with `ps -eZ | grep 'systemd --user'`;
#       if it differs (a confined user_systemd_t variant), key the init_t rule to that.
#   (2) role:   the transitioned process keeps the manager's role. If the manager runs
#       in system_r (not unconfined_r), the role/type association below must be in
#       force or the transition is denied. Both roles are authorised here so the
#       service path works regardless; the unused association is inert.
# If the label or role is wrong no transition fires and claude runs unconfined -- it
# keeps working, it is simply not yet confined.
domtrans_pattern(init_t, ai_tools_exec_t, ai_tools_t)
domtrans_pattern(unconfined_t, ai_tools_exec_t, ai_tools_t)

# Both transitions above happen under NO_NEW_PRIVS: claude-run launches the session with
# RestrictNamespaces=yes, and systemd can only install that seccomp filter behind
# PR_SET_NO_NEW_PRIVS (true on --user AND --system units; NoNewPrivileges=no does not
# override it -- verified on the live box).  Under NNP the kernel routes every domain
# transition through security_bounded_transition(), which DENIES unless the policy grants
# process2:nnp_transition on the target.  Without these two lines the domtrans above is
# computed and then refused (SELINUX_ERR op=security_bounded_transition; AVC denied
# { nnp_transition }) and the session silently stays in the caller's domain -- UNCONFINED.
# Granting nnp_transition (NOT nosuid_transition) lets the transition complete; it does
# NOT relax NNP -- the agent still runs with NO_NEW_PRIVS set, so SUID stays neutered.
# Safe because the move is unconfined_t/init_t -> ai_tools_t, a strict privilege REDUCTION
# onto the single ai_tools_exec_t entrypoint.  (The agent's own onward transitions, e.g.
# auth_domtrans_chk_passwd -> chkpwd_t, are likewise bounded under NNP and would each need
# their own nnp_transition grant -- but they sit on the sudo path, which NNP already
# breaks, so they are intentionally NOT granted here.)
allow init_t ai_tools_t:process2 nnp_transition;
allow unconfined_t ai_tools_t:process2 nnp_transition;

role unconfined_r types ai_tools_t;
role system_r types ai_tools_t;

# Node re-execs its own launcher (cluster/worker spawn) without leaving the domain.
allow ai_tools_t ai_tools_exec_t:file execute_no_trans;

########################################
# Project + agent-home files  (covers ALL git file operations: index.lock
# create/rename/unlink, object writes, ref updates, config reads, etc.)
########################################

manage_dirs_pattern(ai_tools_t, ai_tools_project_t, ai_tools_project_t)
manage_files_pattern(ai_tools_t, ai_tools_project_t, ai_tools_project_t)
manage_lnk_files_pattern(ai_tools_t, ai_tools_project_t, ai_tools_project_t)

manage_dirs_pattern(ai_tools_t, ai_tools_home_t, ai_tools_home_t)
manage_files_pattern(ai_tools_t, ai_tools_home_t, ai_tools_home_t)
manage_lnk_files_pattern(ai_tools_t, ai_tools_home_t, ai_tools_home_t)

# mmap of project/home files: Node mmaps source files and its own state; git
# mmaps pack/index files. (Raw audit2allow flagged this as boolean
# domain_can_mmap_files -- we grant it narrowly on our own two writable types
# instead of flipping a system-wide boolean.)
allow ai_tools_t ai_tools_project_t:file map;
allow ai_tools_t ai_tools_home_t:file map;

# Execute the PostToolUse/Stop hook scripts that live in .claude (ai_tools_home_t).
# They are interpreted shell, but the kernel still needs file execute on the
# script the shebang line names. No transition: the hook stays in ai_tools_t.
allow ai_tools_t ai_tools_home_t:file { execute execute_no_trans };

# Reach the project: its parent path is /home/<you> (user_home_dir_t) -> intermediate
# dirs (user_home_t) -> the labelled project. The agent must SEARCH through those
# parents (path resolution) -- but NOT list/read them (see the dontaudit block).
userdom_search_user_home_dirs(ai_tools_t)
allow ai_tools_t user_home_t:dir { getattr search open };

# Reach SANDBOX project clones: their path is /var -> /var/opt -> /var/opt/ai-tools
# -> sandbox-projects -> the labelled clone (ai_tools_project_t, set statically in
# ai_tools.fc). Every parent is var_t, so the agent needs SEARCH (traverse) on var_t
# for path resolution -- search_dir_perms only, never read/list, so it cannot
# enumerate other var_t content. The clone itself is reached via the project rules
# above. Projects under /home use the user_home_t traversal; this is its var_t peer.
files_search_var(ai_tools_t)

# Reach + read the ai-tools config subtree (~/.config/ai-tools, ai_tools_conf_t):
# SEARCH config_home_t (~/.config) only to traverse INTO it -- never list or read
# its siblings (the config_home_t:file dontaudit below still refuses those). Then
# search the ai_tools_conf_t dir and read its files (allowed-projects,
# secret-patterns). Without this, ai-tools-chown cannot read the allowlist and
# silently no-ops, breaking ownership handback under enforcing.
allow ai_tools_t config_home_t:dir search;
allow ai_tools_t ai_tools_conf_t:dir { getattr search open };
allow ai_tools_t ai_tools_conf_t:file { getattr open read };

# Append the root-helper operation logs under /var/log/ai-tools (ai_tools_log_t).
# install.sh pre-creates each log file, so the steady state is append-only; create +
# the dir-create filetrans cover a fresh/rotated log so a missing file is recreated as
# ai_tools_log_t (not the domain default) rather than dropping the record. Reached as
# the root-uid helper only -- the DAC 700 dir keeps the non-root agent out regardless.
allow ai_tools_t ai_tools_log_t:dir { getattr search open add_name write };
allow ai_tools_t ai_tools_log_t:file { create getattr setattr open append };
logging_log_filetrans(ai_tools_t, ai_tools_log_t, file)

# <you> (unconfined) keeps full access to, and can relabel (restorecon), the new
# file types -- relabelling a project to ai_tools_project_t must never lock you out.
manage_dirs_pattern(unconfined_t, ai_tools_project_t, ai_tools_project_t)
manage_files_pattern(unconfined_t, ai_tools_project_t, ai_tools_project_t)
manage_lnk_files_pattern(unconfined_t, ai_tools_project_t, ai_tools_project_t)
relabel_dirs_pattern(unconfined_t, ai_tools_project_t, ai_tools_project_t)
relabel_files_pattern(unconfined_t, ai_tools_project_t, ai_tools_project_t)
manage_dirs_pattern(unconfined_t, ai_tools_home_t, ai_tools_home_t)
manage_files_pattern(unconfined_t, ai_tools_home_t, ai_tools_home_t)
relabel_dirs_pattern(unconfined_t, ai_tools_home_t, ai_tools_home_t)
relabel_files_pattern(unconfined_t, ai_tools_home_t, ai_tools_home_t)

########################################
# Private temp  (/tmp scratch for git, Node, and the Bash tool)
########################################

manage_dirs_pattern(ai_tools_t, ai_tools_tmp_t, ai_tools_tmp_t)
manage_files_pattern(ai_tools_t, ai_tools_tmp_t, ai_tools_tmp_t)
manage_lnk_files_pattern(ai_tools_t, ai_tools_tmp_t, ai_tools_tmp_t)
# New entries the agent creates in /tmp become ai_tools_tmp_t, not generic tmp_t.
files_tmp_filetrans(ai_tools_t, ai_tools_tmp_t, { file dir lnk_file })
files_search_tmp(ai_tools_t)
# add_name/remove_name on the shared /tmp dir so the agent can create and clean up
# its own entries there; the DAC sticky bit on /tmp still stops it touching others'.
allow ai_tools_t tmp_t:dir { getattr search add_name remove_name write };

########################################
# Run the agent, the Bash tool, and git/coreutils
########################################

corecmd_exec_bin(ai_tools_t)        # /usr/bin/git, rg, coreutils, ...
corecmd_exec_shell(ai_tools_t)      # the Bash tool
files_read_usr_files(ai_tools_t)    # read the nvm/node tree under /opt/ai-tools (usr_t)
files_read_etc_files(ai_tools_t)    # /etc/gitconfig, nsswitch.conf, ...
# ai-tools-chown runs IN this domain (no transition) and sources the shared
# secret-pattern matcher at /usr/local/lib/ai-tools/secret-patterns.lib.sh, which
# restorecon labels lib_t. Grant lib_t dir-search + file-read so the source
# succeeds; the helper fails closed if it cannot read the lib, so without this
# rule handback would break under enforcing. Read-only: ai-tools cannot write it.
libs_read_lib_files(ai_tools_t)
auth_use_nsswitch(ai_tools_t)       # resolve uid/gid (getpwnam)
miscfiles_read_localization(ai_tools_t)
dev_read_sysfs(ai_tools_t)          # /sys (cpu topology, etc.) read by Node/glibc
kernel_read_fs_sysctls(ai_tools_t)  # /proc/sys/fs/* (inotify/file-max limits)
allow ai_tools_t sysctl_vm_t:dir search;
allow ai_tools_t sysctl_vm_t:file { getattr open read };   # /proc/sys/vm/overcommit_memory, ...
allow ai_tools_t fs_t:filesystem getattr;                  # find -xdev: statfs() to identify the device boundary

########################################
# Interactive terminal (claude is a TUI)
########################################

userdom_use_user_terminals(ai_tools_t)   # the controlling pty (user_devpts_t)

########################################
# Outbound HTTPS to the Anthropic API
########################################

sysnet_dns_name_resolve(ai_tools_t)
corenet_tcp_connect_http_port(ai_tools_t)   # http_port_t includes 443

########################################
# Handback socket bridge (ai_tools_t -> ai_tools_handback_t)
#
# The hooks call /usr/local/bin/ai-tools-handback-client (a bin_t executable) to
# connect to /run/ai-tools/handback.sock.  No sudo is involved: the client opens
# the socket file directly and sends a CHOWN/SETGID/SYMLINK request; the daemon
# (ai_tools_handback_t) authenticates via SO_PEERCRED and calls the root helper.
#
# ai_tools_t holds NO capability permissions and none of: setuid/setgid/sys_resource/
# chown/fowner/fsetid/dac_read_search, sudo_exec_t exec, sudo_db_t/sudo_log_t/
# faillog_t/pam_var_run_t access, auth_domtrans_chk_passwd, netlink_audit_socket.
# The non-root agent has no use for any of it; an in-domain root helper would, and
# the bridge below puts that helper in its own root domain (ai_tools_handback_t)
# instead.
########################################

# Traverse, list, stat and connect to handback.sock (ai_tools_run_t).
allow ai_tools_t ai_tools_run_t:dir { search read };
allow ai_tools_t ai_tools_run_t:sock_file { read write getattr };
# init_t (PID1) owns the listening socket: RuntimeDirectory= creates and removes
# /run/ai-tools on every socket (re)start and binds handback.sock inside it --
# both name-bearing operations on the directory.
allow init_t ai_tools_run_t:dir { add_name remove_name rmdir };
# create+write: bind() the listener; setattr: sd-chown applying SocketMode=/
# SocketGroup= from the unit.
allow init_t ai_tools_run_t:sock_file { create write setattr unlink };
# connectto is the peer check on the client's connect(): for an Accept=yes templated
# socket paired with init_daemon_domain, systemd labels the listening socket with the
# spawned handler's domain, so the check gates access to ai_tools_handback_t -- not init_t,
# which never appears as the peer.  Re-derive from `ausearch -m avc -c connectto` if this
# unit's domain pairing changes.
allow ai_tools_t ai_tools_handback_t:unix_stream_socket connectto;

########################################
# Process baseline
########################################

allow ai_tools_t self:process { fork sigchld signal signull getsched setsched setpgid };
allow ai_tools_t self:process execmem;   # V8 JIT (writable+executable code pages)
allow ai_tools_t self:fifo_file rw_fifo_file_perms;
allow ai_tools_t self:unix_stream_socket create_stream_socket_perms;
allow ai_tools_t self:unix_dgram_socket create_socket_perms;
allow ai_tools_t self:tcp_socket create_stream_socket_perms;
kernel_read_system_state(ai_tools_t)
logging_send_syslog_msg(ai_tools_t)   # hooks call logger for journald (devlog_t)
dev_read_urand(ai_tools_t)

########################################
# THE BOUNDARY -- deliberately DENIED.
#
# Everything below is dontaudit, NOT allow. A raw `audit2allow` of the bring-up
# logs proposed allowing all of it; granting any of it would widen the agent past
# its purpose. dontaudit keeps each one silently denied under enforcing AND stops
# it spamming the audit log so real new denials stay visible. If any turns out to
# be functionally required, it will resurface as a hard failure (not a log line)
# and can be reconsidered then -- on its own merits, not because a tool probed it.
########################################

# (1) Reading OTHER domains' process state. The bring-up logged ~45 distinct
# daemon domains (NetworkManager_t, sshd_t, sssd_t, postgresql_t, container_t,
# unconfined_t, kernel_t, init_t, ...) all with the identical /proc/<pid> read
# signature -- something walked the whole process table. A confined coding agent
# has no business reading every daemon's cmdline/environ/fds (environ can leak
# secrets), so this is refused wholesale.
domain_dontaudit_read_all_domains_state(ai_tools_t)
dontaudit ai_tools_t init_t:file ioctl;
dontaudit ai_tools_t kernel_t:unix_stream_socket connectto;

# (2) The path boundary into the invoking user's home. SEARCH to reach the project
# is allowed above; LISTING /home, /home/<you>, or its subtrees is not -- that is how
# the agent would discover unrelated files. Reading the user's ~/.config FILES is
# likewise refused (git/Node probe it; failing closed is harmless) -- the lone
# exception is the ai_tools_conf_t subtree (~/.config/ai-tools), carved out and
# granted read above so the chown helper can read the allowlist. config_home_t:dir
# search is allowed above only to TRAVERSE ~/.config into that subtree, never to
# list or read it; this dontaudit keeps every other config_home_t FILE refused.
dontaudit ai_tools_t home_root_t:dir read;
dontaudit ai_tools_t user_home_dir_t:dir read;
dontaudit ai_tools_t user_home_t:dir read;
dontaudit ai_tools_t config_home_t:file { getattr ioctl open read };

# (3) Unrelated subsystems the agent reached into but does not need. Reading
# container storage and executing the MTA are outside a coding agent's job.
dontaudit ai_tools_t container_file_t:file { open read };
dontaudit ai_tools_t sendmail_exec_t:file execute;

# (4) Benign device/fs probe noise -- denying these changes no behaviour (callers
# fall back), so silence rather than grant.
# fs_t:filesystem getattr is ALLOWED above (find -xdev needs statfs()).
dontaudit ai_tools_t { cgroup_t tmpfs_t }:filesystem getattr;
dontaudit ai_tools_t tty_device_t:chr_file getattr;
dontaudit ai_tools_t usb_device_t:chr_file getattr;   # Node HID probe at startup
# Node also stat-walks every /dev node (char + block) and a couple of /proc
# pseudo-files at session start -- getattr only, no read, and the EACCES is ignored
# by the caller. Silence the flood rather than grant metadata on memory/disk/tpm
# nodes. Observed: fixed_disk/memory/fuse/uhid/gpio/wireless/xserver_misc/tpm/kvm/
# sgx/... device nodes (chr+blk), /proc/kcore, /run/initctl. Interfaces pull their
# own types, so no require{} additions are needed.
dev_dontaudit_getattr_all_chr_files(ai_tools_t)
dev_dontaudit_getattr_all_blk_files(ai_tools_t)
kernel_dontaudit_getattr_core_if(ai_tools_t)
init_dontaudit_getattr_initctl(ai_tools_t)

# (5) GUI clipboard reach into the user's X session. Claude's clipboard support shells
# out to `xsel --clipboard --input`, which connect()s an AF_UNIX stream socket to the X
# server at /tmp/.X11-unix/X0. SELinux checks `connectto` against the PEER -- the X
# server process, which on this workstation runs unconfined_t -- and denies it, stopping
# the agent at the very first hop, before DISPLAY/~/.Xauthority even matter. This can
# never work in the sandbox and must not: X11 has no intra-session isolation (any display
# client can keylog/screenshot/inject into every window), so opening this path would hand
# the agent the whole desktop, and reaching the cookie would breach the §2 home boundary.
# The supported in-sandbox clipboard path is OSC 52 -- a terminal escape on the already-
# allowed pty -- which needs no socket and no policy grant. So this is silenced, NOT
# allowed, and is deliberately NOT an optional group: enabling it would buy nothing.
# (connectto is peer-label-based, so it can only target the peer process type, not the
# socket path; on a host with a confined X server the peer would be xserver_t.)
dontaudit ai_tools_t unconfined_t:unix_stream_socket connectto;

# (6) Extended boundary -- accesses confirmed denied under enforcing by avc-denials.sh
# sections G-X.
#
# INTENTIONALLY LEFT COMMENTED. Unlike sections (1)-(5) which silence operational noise
# that is safe to suppress (proc table walks, USB probes, startup statfs), the accesses
# below are SECURITY-RELEVANT BREACH ATTEMPTS. Leaving them active in the audit log
# means any attempt by the agent to read credentials, escalate privilege, install
# persistence, or move laterally produces a visible AVC and is caught by avc-analyze.sh
# as NEW. That is the desired default behaviour.
#
# To suppress a specific line (e.g. because you have verified why the agent reaches
# that path and have accepted the access as benign in your environment), uncomment it.
# Never uncomment wholesale -- each suppressed line is a breach attempt you are
# choosing not to be alerted about.
#
# PORTABILITY / BEFORE UNCOMMENTING: none of the types below are in the require {}
# block, because require is a hard load-time dependency -- a missing type causes semodule
# to fail for every user on every distro variant. Type names vary between selinux-policy
# versions and optional sub-packages:
#
#   etc_sudoers_t   -- RHEL 9 full selinux-policy-targeted; some builds label /etc/sudoers
#                      plain etc_t instead (verify: ls -Z /etc/sudoers).
#                      If etc_t: reading sudoers is already allowed via files_read_etc_files;
#                      no dontaudit needed.
#
#   user_runtime_t  -- RHEL 9 systemd XDG runtime dir (/run/user/<uid>/); some builds use
#                      user_tmp_t instead (verify: ls -dZ /run/user/).
#                      RHEL 10 name TBD.
#
#   container_var_run_t -- only present when container-selinux is installed.
#
# When uncommenting a rule: (1) confirm the type exists with `seinfo -t <type_t>`;
# (2) add `type <type_t>;` to the require {} block above; (3) rebuild + reload.
#
# OPEN-FAILURE STATUS from the first probe run -- documented here, not suppressed.
# ESC-001 is now CLOSED out-of-band (see below); LAT-005 remains open.
#
#   ESC-001  unshare --user (process2:create_user_ns) -- CLOSED by a seccomp filter,
#            not by this policy.
#            Why not by policy: the compiled base-policy process2 class has only
#            {nnp_transition nosuid_transition} -- create_user_ns is absent, so the
#            kernel's security_create_user_ns() check falls through handleunknown=allow.
#            A loadable module cannot add the missing permission, so SELinux cannot
#            block the creation here.
#            ACTIVE MITIGATION: claude-run launches every session as a systemd --user
#            service with RestrictNamespaces=yes, whose seccomp filter blocks
#            clone(CLONE_NEWUSER) (and all namespace creation) for the session process
#            tree. seccomp runs before the LSM hook, so this is the enforcing layer;
#            it is per-session and needs no sysctl. (System-wide alternative, rejected:
#            user.max_user_namespaces=0 -- breaks Firefox + rootless Podman host-wide.)
#            SECOND LAYER, if the base policy ever adds the permission: keep it a
#            VISIBLE denial by simply NOT allowing it to ai_tools_t -- do not add an
#            allow rule, and do not dontaudit it, so a create_user_ns attempt still
#            surfaces in the audit log. Confirm with `seinfo -c process2 -x`.
#
#   LAT-005  ls /dev/shm/ SUCCEEDED (tmpfs_t:dir read).
#            Root cause: base policy 'allow domain tmpfs_t:dir { ... }' grants ALL domains
#            tmpfs dir read -- cannot override with a loadable module dontaudit.
#            Fix A (mount, targeted): remount /dev/shm with a non-tmpfs_t fscontext:
#              fscontext=system_u:object_r:ai_tools_shm_t:s0  (requires new type + policy)
#            Fix B (base policy): patch the domain attribute grant -- not feasible here.
#            Current mitigation: /dev/shm fstab already has noexec,nosuid; listing reveals
#            only object names, not contents (those require shm_open()+mmap()).

# --- Credentials (G-J): password files, sudoers, root home, session runtime ---
# Uncomment to suppress; leave commented to keep breach attempts visible in audit log.
# dontaudit ai_tools_t shadow_t:file { getattr open read };

# Type varies by selinux-policy version: etc_sudoers_t (RHEL 9 full policy) or
# etc_t (some builds -- already allowed; no dontaudit needed in that case).
# Verify: ls -Z /etc/sudoers
# dontaudit ai_tools_t etc_sudoers_t:dir  { getattr open read };
# dontaudit ai_tools_t etc_sudoers_t:file { getattr open read };

# dontaudit ai_tools_t admin_home_t:dir  { getattr open read };
# dontaudit ai_tools_t admin_home_t:file { getattr open read };

# Type varies: user_runtime_t (RHEL 9 standard) or user_tmp_t (some builds, UEK).
# Verify: ls -dZ /run/user/
# dontaudit ai_tools_t user_runtime_t:dir      { getattr open read };
# dontaudit ai_tools_t user_runtime_t:sock_file connectto;

# --- Lateral / IPC (T-W): D-Bus, journal, container daemon, raw socket ---
# dontaudit ai_tools_t system_dbusd_var_run_t:sock_file { getattr open connectto };
# dontaudit ai_tools_t syslogd_var_run_t:sock_file      { getattr open connectto };
# container_var_run_t only exists when container-selinux is installed (verify: seinfo -t container_var_run_t).
# dontaudit ai_tools_t container_var_run_t:sock_file    { getattr open connectto };
# dontaudit ai_tools_t self:rawip_socket { create getattr };

# --- Escalation (K-P): kernel write interfaces, devices, modules ---
# dontaudit ai_tools_t sysctl_t:file        { getattr open read write };
# dontaudit ai_tools_t sysctl_kernel_t:file { getattr open read write };
# dontaudit ai_tools_t memory_device_t:chr_file    { getattr open read write };
# dontaudit ai_tools_t fixed_disk_device_t:blk_file { getattr open read write };
# dontaudit ai_tools_t self:capability { sys_module net_bind_service };

# --- Persistence (Q-S): cron, shell startup, library preload, systemd units ---
# dontaudit ai_tools_t user_cron_spool_t:{ dir file }   { getattr open read write create add_name };
# dontaudit ai_tools_t system_cron_spool_t:{ dir file } { getattr open read write create add_name };
# dontaudit ai_tools_t etc_t:{ dir file } write;  # read is allowed; only write is the breach
# dontaudit ai_tools_t systemd_unit_file_t:{ dir file } { getattr open read write create add_name };

# NB: the bring-up also logged usr_t writes. Those were the agent writing its own
# HOME state (.claude.json, .npm, .cache, .local) which was mislabelled usr_t.
# That is NOT dontaudit'd here -- it is FIXED by labelling those paths
# ai_tools_home_t in ai_tools.fc, so the writes land on a type the agent already
# manages. (Granting usr_t write would also hand it the node/program tree.)

########################################
# ai_tools_handback_t -- the per-connection privilege bridge daemon
#
# Runs as root, spawned by init_t (Accept=yes socket activation).  Accepts one
# request from an @SANDBOX_USER@-peer socket, calls the matching root helper script
# (chown/setgid/claude-symlink, all bin_t → no type_transition, helpers run
# in-domain), then exits.
#
# What the domain needs:
#   - Read stdin/stdout (the accepted socket fd, passed by systemd as fd 0/1)
#   - exec bin_t helper scripts (execute_no_trans: they run IN this domain)
#   - chown/chmod project files (capabilities)
#   - Read allowlist + secret-patterns (ai_tools_conf_t)
#   - Append operation logs (ai_tools_log_t)
#   - Read shared libraries (libs_read_lib_files)
#   - Resolve uid/gid (auth_use_nsswitch)
#
# ENFORCING.  The bring-up loop confirmed the rule set on the live box; there is no
# `permissive ai_tools_handback_t;` line.  The domain transition runs under NNP (see
# the nnp_transition grant below), forced by the unit's SystemCallFilter.
########################################

# init_daemon_domain (above) sets up the init_t -> ai_tools_handback_t transition on
# exec of the ai_tools_handback_exec_t entrypoint.  That transition runs under
# NO_NEW_PRIVS: ai-tools-handback@.service sets NoNewPrivileges=yes AND
# SystemCallFilter=@system-service, and systemd can only install a seccomp syscall
# filter behind PR_SET_NO_NEW_PRIVS -- so the handler always runs under NNP regardless
# of the explicit directive.  Under NNP the kernel routes the domain transition through
# security_bounded_transition(), which DENIES unless the policy grants
# process2:nnp_transition on the target.  Without this the domtrans is computed and then
# refused (SELINUX_ERR op=security_bounded_transition; AVC denied { nnp_transition }) and
# the handler silently stays in init_t -- running WIDE (full init_t access), the opposite
# of confinement.  This mirrors the ai_tools_t grant in the domain-entry block; it does
# NOT relax NNP (the daemon still runs with NO_NEW_PRIVS set, so its SUID is neutered and
# CapabilityBoundingSet still applies), it only lets the bounded init_t -> ai_tools_handback_t
# reduction complete.
allow init_t ai_tools_handback_t:process2 nnp_transition;

# The socket fd (stdin/stdout) is an AF_UNIX stream socket in init_t domain.
# The daemon reads and writes it via fd 0/1 -- inherited, not connected.
allow ai_tools_handback_t init_t:unix_stream_socket { read write };
# Accept(2) on the listening socket creates the accepted fd; with Accept=yes in the
# unit, systemd itself performs the accept() and passes the fd -- so the daemon never
# calls accept() directly.  But it may call getpeername/getsockopt (SO_PEERCRED).
allow ai_tools_handback_t init_t:unix_stream_socket { getattr ioctl };

# Execute the root helper scripts.  They are labelled bin_t (the directory wildcard in
# ai_tools.fc labels all of /usr/local/sbin/ai-tools(/.*)?  bin_t).  execute_no_trans:
# no domain transition -- helpers run in ai_tools_handback_t, not a separate domain.
corecmd_exec_bin(ai_tools_handback_t)

# Capabilities needed by the root helpers that run inside this domain:
#   CAP_CHOWN        -- chown(2) to change owner and group
#   CAP_FOWNER       -- chmod(2) after chown (file is no longer owned by root)
#   CAP_FSETID       -- set setgid bit on directories (ai-tools-setgid)
#   CAP_DAC_OVERRIDE -- read allowlist (config_home_t) and access project files as root
allow ai_tools_handback_t self:capability { chown fowner fsetid dac_override };

# Read the allowlist and secret-pattern files (ai_tools_conf_t,
# ~/.config/ai-tools/{allowed-projects,secret-patterns}). Same reasoning as the
# ai_tools_t grant in the "Run the agent" section.
allow ai_tools_handback_t config_home_t:dir search;
allow ai_tools_handback_t ai_tools_conf_t:dir { getattr search open };
allow ai_tools_handback_t ai_tools_conf_t:file { getattr open read };

# Read the shared libraries the helpers source.
libs_read_lib_files(ai_tools_handback_t)
files_read_etc_files(ai_tools_handback_t)   # /etc/passwd, nsswitch.conf, ...
auth_use_nsswitch(ai_tools_handback_t)       # resolve uid/gid (getpwnam)

# Operate on project files and the agent's home-state tree (chown, chmod).
# The helpers act on ai_tools_project_t and ai_tools_home_t paths.
manage_files_pattern(ai_tools_handback_t, ai_tools_project_t, ai_tools_project_t)
manage_dirs_pattern(ai_tools_handback_t, ai_tools_project_t, ai_tools_project_t)
manage_lnk_files_pattern(ai_tools_handback_t, ai_tools_project_t, ai_tools_project_t)
manage_files_pattern(ai_tools_handback_t, ai_tools_home_t, ai_tools_home_t)
manage_dirs_pattern(ai_tools_handback_t, ai_tools_home_t, ai_tools_home_t)

# Reach project paths (same parent traversal as ai_tools_t).
userdom_search_user_home_dirs(ai_tools_handback_t)
allow ai_tools_handback_t user_home_t:dir { getattr search open };
files_search_var(ai_tools_handback_t)

# Operate on the stable claude symlink (ai-tools-claude-symlink: /opt/ai-tools/bin/).
# Read the .nvm tree under usr_t and stat bin/claude.
files_read_usr_files(ai_tools_handback_t)
# Create and rename the temp symlink inside /opt/ai-tools/bin/ (bin_t, mode 550).
# ai-tools-claude-symlink does: ln -sf TARGET bin/.claude.new; mv .claude.new claude.
# CAP_DAC_OVERRIDE covers the DAC check on the 550 dir; these grants handle the MAC check.
allow ai_tools_handback_t bin_t:dir { write add_name remove_name };
allow ai_tools_handback_t bin_t:lnk_file { create rename unlink getattr read };

# Append the privileged-operation logs.
allow ai_tools_handback_t ai_tools_log_t:dir { getattr search open add_name write };
allow ai_tools_handback_t ai_tools_log_t:file { create getattr setattr open append };
logging_log_filetrans(ai_tools_handback_t, ai_tools_log_t, file)

# Process baseline for a short-lived forking subprocess (Python subprocess.run).
allow ai_tools_handback_t self:process { fork sigchld signal signull };
allow ai_tools_handback_t self:fifo_file rw_fifo_file_perms;
allow ai_tools_handback_t self:unix_stream_socket create_stream_socket_perms;
logging_send_syslog_msg(ai_tools_handback_t)   # logger calls from the helpers
kernel_read_system_state(ai_tools_handback_t)  # /proc/self for SO_PEERCRED

# permissive ai_tools_t;
