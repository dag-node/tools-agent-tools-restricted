# File contexts shipped with the ai_tools module (fixed paths only).
#
# The claude entrypoint -- a standalone ELF reached via two symlinks
# (/opt/ai-tools/bin/claude -> versioned bin/claude -> claude.exe). Labelling the
# final ELF as ai_tools_exec_t is what drives the unconfined_t -> ai_tools_t
# transition on exec. The [^/]+ matches any Node version dir; a Node upgrade installs the
# new claude.exe mislabelled (bin_t), and the nvm-update timer re-applies this label
# automatically (ai-tools-relabel-entrypoint, run as root), or run `ai-tools --relabel`.
# Until relabelled, claude-run fail-closes (refuses to launch) rather than run unconfined.
/opt/ai-tools/\.nvm/versions/node/[^/]+/lib/node_modules/@anthropic-ai/claude-code/bin/claude\.exe  --  gen_context(system_u:object_r:ai_tools_exec_t,s0)
# The rest of the nvm node tree is left to its default usr_t/bin_t/lib_t -- READ-ONLY
# to ai_tools_t (files_read_usr_files / libs_read_lib_files / corecmd_exec_bin), so the
# agent cannot modify its own toolchain mid-session. Node/npm self-management is done
# out-of-band by the scheduled nvm-update timer, which runs unconfined and can write
# this tree; the agent's in-session `npm install -g`/`update -g` is denied by design.
# (claude.exe is hard-linked to the platform package's ELF under
# node_modules/@anthropic-ai/claude-code-<arch>/; install-selinux.sh's verify_entrypoint
# restorecon's claude.exe LAST, so the shared inode lands ai_tools_exec_t regardless of
# the bulk-relabel order. Relabel via `install-selinux.sh rebuild`/`relabel`, never a
# bare restorecon of the tree, which could leave the inode lib_t and trip the
# fail-closed launch preflight.)

# The root helpers grouped under one dir (chown, setgid, claude-symlink, lockdown).
# They run IN ai_tools_handback_t (bin_t, execute_no_trans -- no separate domain).
# Stated explicitly so restorecon labels the dir and all contents consistently.
/usr/local/sbin/ai-tools(/.*)?  gen_context(system_u:object_r:bin_t,s0)
# The handback daemon gets its own entrypoint label so init_t transitions into
# ai_tools_handback_t on exec (more specific than the wildcard above).
/usr/local/sbin/ai-tools/ai-tools-handback  --  gen_context(system_u:object_r:ai_tools_handback_exec_t,s0)

# The handback socket client (called by the agent hooks and nvm-update.sh).
# Lives in /usr/local/bin -- the default bin_t for that path -- no special label.

# The handback socket runtime directory and socket file.  Created by systemd when
# ai-tools-handback.socket activates (RuntimeDirectory=ai-tools, mode 0750
# root:ai-tools).  ai_tools_t needs search on the dir and read/write on the
# sock_file; restorecon here keeps labels consistent after a socket restart.
/run/ai-tools(/.*)?  gen_context(system_u:object_r:ai_tools_run_t,s0)
# Twin of the above for the legacy path: file_contexts.subs_dist rewrites every
# /run/* lookup to /var/run/* before matching (the /run<-/var/run compat shim),
# so matchpathcon/restorecon/RuntimeDirectory= labelling never reaches the entry
# above -- only this one. cockpit and mount declare both forms for the same reason.
/var/run/ai-tools(/.*)?  gen_context(system_u:object_r:ai_tools_run_t,s0)

# The root-helper operation logs. ai-tools-chown / -setgid / -claude-symlink run IN
# ai_tools_handback_t and append here; the domain is granted append/create on
# ai_tools_log_t in ai_tools.te. DAC keeps it root-only (dir 700, files 600).
/var/log/ai-tools(/.*)?  gen_context(system_u:object_r:ai_tools_log_t,s0)

# The agent's own config/state dir -- a private writable area, so the policy need
# not grant write to the whole nvm tree (usr_t). The <you>-owned control files inside
# (settings.json, post-tool-hook.sh) remain protected by DAC regardless of label.
/opt/ai-tools/\.claude(/.*)?  gen_context(system_u:object_r:ai_tools_home_t,s0)

# The rest of the agent's HOME state. HOME is /opt/ai-tools, whose base is usr_t,
# so without these the agent's own writes to .claude.json / .npm / .cache / .local
# / .config land on usr_t -- and granting the domain usr_t write would also hand it
# the read-only node/program tree. Labelling just these paths ai_tools_home_t keeps
# the writes on a type the domain already manages, and leaves .nvm (usr_t,
# read-only) and bin (bin_t, the locked control-plane) untouched.
/opt/ai-tools/\.claude\.json  --  gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.npm(/.*)?         gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.cache(/.*)?       gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.local(/.*)?       gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.config(/.*)?      gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.gitconfig     --  gen_context(system_u:object_r:ai_tools_home_t,s0)

# Approved PROJECT dirs under /home are NOT listed here -- their paths are dynamic.
# They are labelled ai_tools_project_t per-project with `semanage fcontext` by
# install-selinux.sh (reading ~/.config/ai-tools/allowed-projects).
#
# SANDBOX project clones are the exception: they all live under one fixed parent,
# so every directory directly under sandbox-projects/ is a project and is labelled
# statically here. This is what lets `ai-tools --sandbox-create` self-label a fresh
# clone with a plain restorecon -- no per-project semanage and no root, since
# unconfined_t is granted relabel to ai_tools_project_t in ai_tools.te. The parent
# dirs (/var/opt/ai-tools and sandbox-projects itself) stay var_t and are reached
# via the files_search_var traversal grant in ai_tools.te.
/var/opt/ai-tools/sandbox-projects/[^/]+(/.*)?  gen_context(system_u:object_r:ai_tools_project_t,s0)
