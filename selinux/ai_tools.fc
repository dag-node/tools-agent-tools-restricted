# File contexts shipped with the ai_tools module (fixed paths only).
#
# The claude entrypoint -- a standalone ELF reached via two symlinks
# (/opt/ai-tools/bin/claude -> versioned bin/claude -> claude.exe). Labelling the
# final ELF as ai_tools_exec_t is what drives the unconfined_t -> ai_tools_t
# transition on exec. The [^/]+ matches any Node version dir; after a Node upgrade
# re-apply with `install-selinux.sh relabel` (the new claude.exe is created
# unlabelled, which fails OPEN -- claude runs unconfined until relabelled).
/opt/ai-tools/\.nvm/versions/node/[^/]+/lib/node_modules/@anthropic-ai/claude-code/bin/claude\.exe  --  gen_context(system_u:object_r:ai_tools_exec_t,s0)

# The root sudo-helpers, grouped under one dir (chown, setgid, claude-symlink,
# lockdown). They run IN ai_tools_t (sudo, no domain transition), so they need NO
# entrypoint label -- bin_t is the default for /usr/local/sbin and is what
# ai_tools_t is already allowed to execute. Stated explicitly so a restorecon of
# the dir labels it (and its files) consistently regardless of how they were created.
/usr/local/sbin/ai-tools(/.*)?  gen_context(system_u:object_r:bin_t,s0)

# The root-helper operation logs. ai-tools-chown / -setgid / -claude-symlink run IN
# ai_tools_t and append here, so the dir and its files must carry ai_tools_log_t (the
# domain is granted append/create on that type in ai_tools.te). DAC keeps it root-only
# (dir 700, files 600); this label is what makes the writes succeed under enforcing.
/var/log/ai-tools(/.*)?  gen_context(system_u:object_r:ai_tools_log_t,s0)

# The agent's own config/state dir -- a private writable area, so the policy need
# not grant write to the whole nvm tree (usr_t). The <you>-owned control files inside
# (settings.json, post-tool-hook.sh) remain protected by DAC regardless of label.
/opt/ai-tools/\.claude(/.*)?  gen_context(system_u:object_r:ai_tools_home_t,s0)

# The rest of the agent's HOME state. HOME is /opt/ai-tools, whose base is usr_t,
# so without these the agent's own writes to .claude.json / .npm / .cache / .local
# / .config land on usr_t -- and granting the domain usr_t write would also hand it
# the read-only node/program tree. Labelling just these paths ai_tools_home_t keeps
# the writes on a type the domain already manages, and leaves .nvm (usr_t,
# read-only) and bin (bin_t, the locked control-plane) untouched.
/opt/ai-tools/\.claude\.json  --  gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.npm(/.*)?         gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.cache(/.*)?       gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.local(/.*)?       gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.config(/.*)?      gen_context(system_u:object_r:ai_tools_home_t,s0)
/opt/ai-tools/\.gitconfig     --  gen_context(system_u:object_r:ai_tools_home_t,s0)

# Approved PROJECT dirs under /home are NOT listed here -- their paths are dynamic.
# They are labelled ai_tools_project_t per-project with `semanage fcontext` by
# install-selinux.sh (reading ~/.config/ai-tools/allowed-projects).
#
# SANDBOX project clones are the exception: they all live under one fixed parent,
# so every directory directly under sandbox-projects/ is a project and is labelled
# statically here. This is what lets `ai-tools --sandbox-create` self-label a fresh
# clone with a plain restorecon -- no per-project semanage and no root, since
# unconfined_t is granted relabel to ai_tools_project_t in ai_tools.te. The parent
# dirs (/var/opt/ai-tools and sandbox-projects itself) stay var_t and are reached
# via the files_search_var traversal grant in ai_tools.te.
/var/opt/ai-tools/sandbox-projects/[^/]+(/.*)?  gen_context(system_u:object_r:ai_tools_project_t,s0)
