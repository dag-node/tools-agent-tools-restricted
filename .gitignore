.idea/
.env/
# Compiled policy packages are build artifacts -- except the core module, which
# ships prebuilt so a normal install needs no selinux-policy-devel toolchain.
selinux/policy/*.pp
!selinux/policy/ai_tools.pp
selinux/policy/tmp/
selinux/avc/.avc-last-run
selinux/avc/audits/
.avc-scratch/
ai_tools_exec_t
# Self-cleaning fixture dir from tests/integration/hooks.sh (left only if a run is killed).
.handback-test.*

# Python bytecode cache -- created next to the handback daemon/client when they are run or
# imported (e.g. a test loading the daemon); never a source artifact.
__pycache__/
*.pyc